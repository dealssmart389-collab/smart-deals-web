import os
import google.generativeai as genai
from flask import Flask, request, jsonify
from flask_cors import CORS # لضمان عمل الموقع مع السيرفر المحلي
from dotenv import load_dotenv

load_dotenv()
app = Flask(__name__)
CORS(app) # السماح للمتصفح بالاتصال بالسيرفر

# إعداد مفتاح الذكاء الاصطناعي
genai.configure(api_key=os.getenv("GEMINI_API_KEY"))
model = genai.GenerativeModel('gemini-1.5-flash')

@app.route('/ask_timo', methods=['POST'])
def ask_timo():
    user_query = request.json.get('query')
    
    # برمجة شخصية تيمو السيادية
    prompt = f"أنت تيمو (TIMO)، ذكاء اصطناعي متطور لمنظومة Benalal AI 2026. " \
             f"صانعك هو منير بن علال (Mounir Benalal). أجب بذكاء واحترافية " \
             f"وبلهجة مغربية خفيفة عند الضرورة. السؤال: {user_query}"
    
    try:
        response = model.generate_content(prompt)
        return jsonify({"answer": response.text})
    except Exception as e:
        return jsonify({"answer": "عذراً يا سيد منير، حدث خطأ في الاتصال بالعقل الخارجي."}), 500

if __name__ == '__main__':
    app.run(host='127.0.0.1', port=5000)
